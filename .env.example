# =============================================================================
# EchoFind — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- LLM / embeddings / rerank ---
GEMINI_API_KEY=your-google-ai-studio-key          # Google Gemini (OpenAI-compatible endpoint)
OPENAI_API_KEY=your-openai-key                     # text-embedding-3-large embeddings
PINECONE_API_KEY=your-pinecone-key                 # dense + sparse vector search / rerank inference
ELEVEN_LABS_API_KEY=your-elevenlabs-key            # optional (text-to-speech)

# --- Vector indexes (Pinecone) ---
PINECONE_INDEX_NAME=echofind-dense
PINECONE_SPARSE_INDEX_NAME=echofind-sparse
PINECONE_SPARSE_INDEX_HOST=                        # optional; resolved via client if blank

# --- AWS (prefer an attached IAM role; otherwise set keys here) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# --- Relational store (PostgreSQL / RDS) for chunk + episode metadata ---
RDS_HOST=your-db-host.example.com
RDS_PORT=5432
RDS_DATABASE=podcast_content
RDS_USERNAME=db_user
RDS_PASSWORD=your-db-password
RDS_TABLE_NAME=clips

# --- Optional: trained BM25 sparse model in S3 (falls back to a default model) ---
# BM25_S3_BUCKET=echofind-models
# BM25_S3_KEY=models/bm25/bm25_model.pkl

# --- Optional tuning overrides (sensible defaults live in config.py) ---
# RECENT_WINDOW_DAYS_DEFAULT=21
# MAX_TRACKED_ENTITIES=15
# EPISODE_SELECTION_LIMIT=15
